{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tuniq",
  "version": "0.1.0",
  "identifier": "dev.tuniq.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:10182",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tuniq",
        "width": 720,
        "height": 680,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:* https://tuniq.dev https://*.tuniq.dev ws://localhost:* wss://*; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
